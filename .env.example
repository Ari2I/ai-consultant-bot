# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=

# Chat ID админов (владелец бизнеса + опционально менеджеры), через запятую
ADMIN_CHAT_IDS=

# Прокси для подключения к Telegram Bot API — заполните, только если
# api.telegram.org заблокирован в вашей сети (актуально для многих
# сетей в России). Поддерживается SOCKS5 и HTTP. Пусто — прямое
# подключение.
# PROXY_URL=socks5://user:password@1.2.3.4:1080
PROXY_URL=

# GigaChat API (Сбер) — Authorization key получаете в личном
# кабинете https://developers.sber.ru/studio/ (раздел проекта
# GigaChat API -> Настройки API -> Получить ключ). Это строка вида
# "ключ_в_base64" (client_id:client_secret, уже закодированный) — SDK
# сам обменивает его на access-токен по протоколу OAuth2 и обновляет
# токен автоматически (живёт ~30 минут), вручную ничего обновлять не
# нужно.
GIGACHAT_CREDENTIALS=
# GIGACHAT_API_PERS — доступ для физлиц (для разработки и небольших
# проектов достаточно). Для юрлиц/ИП — GIGACHAT_API_B2B (пакеты
# токенов) или GIGACHAT_API_CORP (pay-as-you-go).
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Актуальная (07.2026) базовая модель. Есть также GigaChat-2-Pro и
# GigaChat-2-Max — мощнее и дороже, для более сложных задач.
GIGACHAT_MODEL=GigaChat-2
# Для TLS-соединения с GigaChat API обязателен корневой сертификат
# НУЦ Минцифры — без него запросы будут падать с ошибкой проверки
# сертификата. Подробности и ссылка на сертификат — в README и
# DEPLOYMENT.md. Если сертификат ещё не установлен и нужно быстро
# проверить бота локально, можно временно отключить проверку
# (НЕ для продакшена):
# GIGACHAT_VERIFY_SSL_CERTS=false
GIGACHAT_VERIFY_SSL_CERTS=true
# Путь к файлу сертификата, если он не в системном хранилище ОС.
GIGACHAT_CA_BUNDLE_FILE=
GIGACHAT_MAX_RETRIES=2
GIGACHAT_RETRY_BACKOFF_SECONDS=1.0
GIGACHAT_REQUEST_TIMEOUT=30

# Путь к базе данных (SQLite по умолчанию, можно указать PostgreSQL)
DATABASE_URL=sqlite:///knowledge_base.db

# Локальная многоязычная модель эмбеддингов (sentence-transformers)
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Порог косинусного сходства, ниже которого вопрос эскалируется человеку
SIMILARITY_THRESHOLD=0.75
# Сколько наиболее похожих фрагментов подавать в контекст модели
TOP_K_CHUNKS=5
# Параметры чанкинга документов (в символах)
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Лимит вопросов в минуту на одного клиента (защита от флуда)
RATE_LIMIT_PER_MINUTE=10
